# tap-to-tmux configuration
# Copy this to ~/.config/tap-to-tmux/config.env and edit for your setup

# --- Required ---

# ntfy topic — unique string that identifies YOUR notification channel
# Generate one: python3 -c "import secrets; print(f'tap-to-tmux-{secrets.token_hex(8)}')"
NTFY_TOPIC=""

# Machine display name (shown in notification titles)
MACHINE=""

# SSH connection for tap-to-connect deep links
SSH_USER=""
SSH_HOST=""  # hostname, IP, or Tailscale name

# --- Optional ---

# ntfy server URL (defaults to public ntfy.sh if empty)
# For self-hosted: NTFY_SERVER="https://ntfy.yourdomain.com"
NTFY_SERVER=""

# ntfy access token — required if your ntfy server uses auth-default-access: deny
# Generate via: docker exec ntfy ntfy token add --label="tap-to-tmux" USERNAME
# Leave empty for public ntfy.sh or open self-hosted servers.
NTFY_TOKEN=""

# Blink Shell x-callback-url key (iOS only — leave empty to disable deep links)
# Find in Blink Settings > x-callback-url
BLINK_KEY=""

# Termux deep links (Android — set to "true" to enable tap-to-connect via Termux)
# Requires: Termux app + allow-external-apps=true in ~/.termux/termux.properties
TERMUX_ENABLED=""

# Slack incoming webhook URL (leave empty to disable Slack notifications)
SLACK_WEBHOOK_URL=""

# Projects directory — tmux sessions matching directories here are monitored
# Default: $HOME/projects
PROJECTS_DIR=""

# Excluded directories — colon-separated list of path prefixes that will NOT trigger
# notifications. Useful for personal notes, scratch dirs, or low-signal projects.
# Example: NOTIFY_EXCLUDE_DIRS="/data/notes:/home/user/scratch"
NOTIFY_EXCLUDE_DIRS=""

# Excluded session patterns — colon-separated list of glob patterns matched against
# tmux session names. Matching sessions will NOT trigger NTM monitor notifications.
# Useful for autonomous/batch sessions that generate too many alerts.
# Example: NOTIFY_EXCLUDE_SESSIONS="autonomous-*:batch-*:tmp-*"
NOTIFY_EXCLUDE_SESSIONS=""

# Remote home directory on the SSH target used by deep links.
# If unset, scripts assume /home/$SSH_USER. Set this on remote macOS or
# custom home paths, e.g. SSH_REMOTE_HOME="/Users/yourname".
SSH_REMOTE_HOME=""
